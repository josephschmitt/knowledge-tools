# Copy to .env for local dev (run: node --env-file=.env dist/index.js).
# In the homelab the container gets these from docker-compose instead.

# Public origin the server is reached at (OAuth resource id + MCP endpoint base).
# Local dev: http://localhost:3000   Production: https://knowledge.mcp.example.com
PUBLIC_URL=http://localhost:3000

# Port the server listens on.
PORT=3000

# Vault filesystem root. Local dev: the repo path. Container: /vault (bind mount).
VAULT_ROOT=/home/USER/knowledge

# --- Cloudflare Access (OIDC) ---
# Copy these from the Access for SaaS OIDC app: Zero Trust → Access controls →
# Applications → the "Claude" app. The server only VALIDATES tokens; Cloudflare issues them.

# REQUIRED. The app's Issuer endpoint.
CF_ISSUER=https://example.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<CLIENT_ID>

# REQUIRED. The app's Client ID — also the expected token audience.
CF_CLIENT_ID=<CLIENT_ID>

# Optional — default to ${CF_ISSUER}/jwks and the standard Cloudflare paths. Set explicitly
# from the app's Key / Authorization / Token endpoints if they differ.
# CF_JWKS_URL=https://example.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<CLIENT_ID>/jwks
# CF_AUTHORIZATION_ENDPOINT=https://example.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<CLIENT_ID>/authorization
# CF_TOKEN_ENDPOINT=https://example.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<CLIENT_ID>/token

# Optional tuning
# MAX_RESULT_CHARS=140000

# DNS-rebinding protection is off by default (OAuth is the gate; claude.ai's fetch may
# omit Origin). Set to true only if you also tune ALLOWED_HOSTS / ALLOWED_ORIGINS.
# ENABLE_DNS_REBINDING_PROTECTION=false
# ALLOWED_HOSTS=knowledge.mcp.example.com
# ALLOWED_ORIGINS=https://claude.ai
