# systemd USER service template — generated into ~/.config/systemd/user/knowledge-synthesize.service
# by scripts/install.sh, which fills in @TOOLS_REPO@ (this repo, where the worker lives) and
# @VAULT_REPO@ (the vault repo it operates on). Edit this template, then re-run install.sh.
#
# Runs one ephemeral whole-corpus /synthesize pass: reconciles wiki/ drift + contradictions,
# finds new cross-note connections, and OPENS judgment-call GitHub issues. Heavy + infrequent
# (cadence via KNOWLEDGE_SYNTHESIZE_ONCALENDAR). Unlike the compile, it runs `gh` from *inside*
# the Claude run, so PATH must reach gh and HOME must reach its auth (~/.config/gh).
[Unit]
Description=Synthesize the vault wiki (reconcile + connect; opens judgment-call issues)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Point the worker at the vault; vault-job.sh cd's into KNOWLEDGE_REPO.
Environment=KNOWLEDGE_REPO=@VAULT_REPO@
# gh (and claude) live in the nix/local profiles, which aren't on the default systemd user
# PATH. Claude shells out to `gh` for the issue calls, so those dirs must be here. HOME is set
# by the user manager and gives gh its auth at ~/.config/gh.
Environment=PATH=%h/.nix-profile/bin:%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=@TOOLS_REPO@/scripts/vault-job.sh synthesize
# Whole-corpus opus pass can take a while.
TimeoutStartSec=3600

[Install]
WantedBy=default.target
