# Copy to .env for local dev (run: node --env-file=.env dist/index.js).
# In the homelab the container gets these from docker-compose instead.

# The server exposes both a Streamable-HTTP MCP endpoint (/mcp) and a REST API (/api/v1),
# backed by the same vault core and gated by the same optional auth below. No separate config.

# Public origin the server is reached at (the MCP endpoint base; also the default allowed Host
# for DNS-rebinding protection). Local dev: http://localhost:3000   Prod: https://knowledge.example.com
PUBLIC_URL=http://localhost:3000

# Port the server listens on.
PORT=3000

# Log level: fatal|error|warn|info|debug|trace|silent. Default info. Use debug to see
# per-request lines when troubleshooting a connector.
# LOG_LEVEL=info

# Vault filesystem root. Local dev: the repo path. Container: /vault (bind mount).
VAULT_ROOT=/path/to/vault

# --- Authentication (optional, OFF by default) ---
# Unset → the server does NO auth and trusts its network; run it behind an authenticating proxy
# (see service/README.md). Set ALL THREE → the server validates a JWT access token on every /mcp
# and /api/v1 request and advertises its authorization server for client discovery (RFC 9728). Vendor-neutral:
# point them at any OIDC issuer (Cloudflare Access, Auth0, Keycloak, ...).
# KNOWLEDGE_AUTH_ISSUER=https://example.cloudflareaccess.com
# KNOWLEDGE_AUTH_JWKS_URL=https://example.cloudflareaccess.com/cdn-cgi/access/certs
# KNOWLEDGE_AUTH_AUDIENCE=<application-aud-tag-or-api-audience>
# Header carrying the token. Default 'authorization' (Bearer ...); set to a proxy-injected header
# such as 'cf-access-jwt-assertion' when an edge gate (e.g. Cloudflare Access) injects the JWT.
# KNOWLEDGE_AUTH_TOKEN_HEADER=authorization

# --- Judgment-call review channel (optional) ---
# The list_questions / get_question / answer_question tools default to the file queue under
# inbox/.review/ (no external creds, writes only inbox/). To instead back them with the vault's
# GitHub issues — so the same tools work when the host runs the GitHub-issue channel, and
# answering here comments + labels the issue vault:answered for /resolve to close — set both:
# KNOWLEDGE_GITHUB_TOKEN=<PAT with issues:read+write on the vault repo>
# KNOWLEDGE_GITHUB_REPO=owner/vault
# Optional GitHub Enterprise API base (default https://api.github.com).
# KNOWLEDGE_GITHUB_API_URL=https://api.github.com
# Channel is auto-detected (github when the token+repo are set, else files); force it explicitly:
# KNOWLEDGE_REVIEW_CHANNEL=files
# Same name on the host (the synthesize/resolve jobs read KNOWLEDGE_REVIEW_CHANNEL too) — set it
# to the same value in both places so both halves of the loop use one surface.

# Optional tuning
# MAX_RESULT_CHARS=140000

# DNS-rebinding protection is off by default (the proxy is the gate; claude.ai's fetch may omit
# Origin). Set to true only if you also tune ALLOWED_HOSTS / ALLOWED_ORIGINS.
# ENABLE_DNS_REBINDING_PROTECTION=false
# ALLOWED_HOSTS=knowledge.example.com
# ALLOWED_ORIGINS=https://claude.ai
